e(220, 20)"><g class="legend-item" transform="translate(0, 0)" style="cursor: pointer;"><line x1="0" x2="20" y1="0" y2="0" stroke="#1f77b4" stroke-width="2"></line><text x="25" y="0" dy="0.35em" class="legend-text">Ceres</text></g></g><g class="zoom-controls" transform="translate(100, 10)"><g class="reset-zoom-btn" style="cursor: pointer;"><rect width="80" height="25" rx="3" fill="#f0f0f0" stroke="#ccc" stroke-width="1"></rect><text x="40" y="17" text-anchor="middle" font-size="11px" fill="#333">Reset Zoom</text></g></g></g><defs><clipPath id="chart-clip"><rect width="200" height="420"></rect></clipPath></defs></svg></div><div class="spectral-tooltip-container"></div></div>"`;

