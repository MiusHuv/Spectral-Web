exports[`Visual Regression Tests > ExportManager Component > should render closed state consistently > export-manager-closed.html 1`] = `"<div class="export-manager"><div class="export-manager__header"><h3>Export Data</h3></div><div class="export-manager__content"><div class="export-manager__info"><p>Selected asteroids: <strong>0</strong></p></div><div class="export-manager__options"><div class="export-option-group"><label class="export-option-group__label">Export Type</label><div class="export-option-group__controls"><label class="radio-option"><input type="radio" name="exportType" value="data" checked=""><span>Asteroid Data</span></label><label class="radio-option"><input type="radio" name="exportType" value="spectrum"><span>Spectral Data</span></label><label class="radio-option"><input type="radio" name="exportType" value="visualization"><span>Chart Visualization</span></label></div></div><div class="export-option-group"><label class="export-option-group__label">Format</label><div class="export-option-group__controls"><label class="radio-option"><input type="radio" name="format" value="csv" checked=""><span>CSV</span></label><label class="radio-option"><input type="radio" name="format" value="json"><span>JSON</span></label></div></div><div class="export-option-group"><label class="export-option-group__label">Additional Options</label><div class="export-option-group__controls"><label class="checkbox-option"><input type="checkbox"><span>Include spectral data</span></label></div></div></div><div class="export-manager__actions"><button class="export-button export-button--primary" disabled="">Export CSV</button></div></div></div>"`;

