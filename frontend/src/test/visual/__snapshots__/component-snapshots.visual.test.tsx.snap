exports[`Visual Regression Tests > PropertiesPanel Component > should render missing data placeholders consistently > properties-panel-missing-data.html 1`] = `"<div class="properties-panel "><div class="properties-header"><h3>Asteroid Properties</h3><div class="selection-count">1 asteroid selected</div></div><div class="properties-content"><div class="single-asteroid-view"><div class="asteroid-header"><h4>Ceres</h4><div class="asteroid-id">ID: 1</div></div><div class="properties-sections"><div class="property-section identification-section "><h5>Identification</h5><div class="property-grid"><div class="property-row  "><div class="property-label">Official Number:</div><div class="property-value">1.000</div></div><div class="property-row  "><div class="property-label">Proper Name:</div><div class="property-value">Ceres</div></div><div class="property-row  no-value"><div class="property-label">Provisional Designation:</div><div class="property-value"><span class="na-value">N/A</span></div></div></div></div><div class="property-section classification-section "><h5>Classification</h5><div class="property-grid"><div class="property-row  "><div class="property-label">Bus-DeMeo Class:</div><div class="property-value">C</div></div><div class="property-row  "><div class="property-label">Tholen Class:</div><div class="property-value">G</div></div><div class="property-row  no-value"><div class="property-label">Orbital Class:</div><div class="property-value"><span class="na-value">N/A</span></div></div></div></div><div class="property-section orbital-section "><h5>Orbital Elements</h5><div class="property-grid"><div class="property-row  "><div class="property-label">Semi-major Axis:</div><div class="property-value">2.770<span class="unit"> AU</span></div></div><div class="property-row  "><div class="property-label">Eccentricity:</div><div class="property-value">0.076000</div></div><div class="property-row  "><div class="property-label">Inclination:</div><div class="property-value">10.600<span class="unit"> °</span></div></div><div class="property-row  "><div class="property-label">Orbital Period:</div><div class="property-value">4.600<span class="unit"> years</span></div></div><div class="property-row  no-value"><div class="property-label">Perihelion Distance:</div><div class="property-value"><span class="na-value">N/A</span></div></div><div class="property-row  no-value"><div class="property-label">Aphelion Distance:</div><div class="property-value"><span class="na-value">N/A</span></div></div></div></div><div class="property-section physical-section "><h5>Physical Properties</h5><div class="property-grid"><div class="property-row  no-value"><div class="property-label">Diameter:</div><div class="property-value"><span class="na-value">N/A</span></div></div><div class="property-row  no-value"><div class="property-label">Albedo:</div><div class="property-value"><span class="na-value">N/A</span></div></div><div class="property-row  "><div class="property-label">Rotation Period:</div><div class="property-value">9.070<span class="unit"> hours</span></div></div><div class="property-row  no-value"><div class="property-label">Density:</div><div class="property-value"><span class="na-value">N/A</span></div></div></div></div></div></div></div></div>"`;

exports[`Visual Regression Tests > PropertiesPanel Component > should render multiple asteroid comparison consistently > properties-panel-comparison.html 1`] = `"<div class="properties-panel "><div class="properties-header"><h3>Asteroid Properties</h3><div class="selection-count">2 asteroids selected</div></div><div class="properties-content"><div class="multiple-asteroids-view"><div class="comparison-table-wrapper"><table class="comparison-table"><thead><tr><th scope="col" class="comparison-label-col">Attribute</th><th scope="col" class="comparison-col "><button type="button" class="comparison-col-button" aria-pressed="false">Ceres</button><span class="comparison-subtitle">ID: 1</span></th><th scope="col" class="comparison-col "><button type="button" class="comparison-col-button" aria-pressed="false">Vesta</button><span class="comparison-subtitle">ID: 2</span></th></tr></thead><tbody><tr><th scope="row" class="comparison-label-col">Designation</th><td class="comparison-value ">Ceres</td><td class="comparison-value ">Vesta</td></tr><tr><th scope="row" class="comparison-label-col">Official Number</th><td class="comparison-value ">1.000</td><td class="comparison-value ">4.000</td></tr><tr><th scope="row" class="comparison-label-col">Provisional Designation</th><td class="comparison-value "><span class="na-value">N/A</span></td><td class="comparison-value "><span class="na-value">N/A</span></td></tr><tr><th scope="row" class="comparison-label-col">Orbital Class</th><td class="comparison-value "><span class="na-value">N/A</span></td><td class="comparison-value "><span class="na-value">N/A</span></td></tr><tr><th scope="row" class="comparison-label-col">Semi-major Axis</th><td class="comparison-value ">2.770<span class="unit"> AU</span></td><td class="comparison-value ">2.360<span class="unit"> AU</span></td></tr><tr><th scope="row" class="comparison-label-col">Eccentricity</th><td class="comparison-value ">0.076000</td><td class="comparison-value ">0.089000</td></tr><tr><th scope="row" class="comparison-label-col">Orbital Period</th><td class="comparison-value ">4.600<span class="unit"> years</span></td><td class="comparison-value ">3.600<span class="unit"> years</span></td></tr><tr><th scope="row" class="comparison-label-col">Diameter</th><td class="comparison-value ">939.400<span class="unit"> km</span></td><td class="comparison-value ">525.400<span class="unit"> km</span></td></tr><tr><th scope="row" class="comparison-label-col">Albedo</th><td class="comparison-value ">0.090000</td><td class="comparison-value ">0.420000</td></tr><tr><th scope="row" class="comparison-label-col">Rotation Period</th><td class="comparison-value ">9.070<span class="unit"> hours</span></td><td class="comparison-value ">5.340<span class="unit"> hours</span></td></tr><tr><th scope="row" class="comparison-label-col">Density</th><td class="comparison-value "><span class="na-value">N/A</span></td><td class="comparison-value "><span class="na-value">N/A</span></td></tr></tbody></table></div></div></div></div>"`;

