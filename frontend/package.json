{
  "name": "asteroid-spectral-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:prod": "NODE_ENV=production npm run build",
    "build:staging": "NODE_ENV=staging npm run build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "preview:prod": "vite preview --port 4173 --host",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:integration": "start-server-and-test dev http://localhost:3000 'cypress run'",
    "test:performance": "vitest run --config vitest.performance.config.ts",
    "test:visual": "vitest run --config vitest.visual.config.ts",
    "test:all": "npm run test && npm run test:e2e && npm run test:performance"
  },
  "dependencies": {
    "@types/react-window": "^1.8.8",
    "axios": "^1.6.0",
    "d3": "^7.8.5",
    "marked": "^15.0.12",
    "marked-gfm-heading-id": "^4.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "react-window": "^2.2.0"
  },
  "devDependencies": {
    "@cypress/vite-dev-server": "^5.0.7",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/d3": "^7.4.3",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.0.4",
    "artillery": "^2.0.3",
    "canvas": "^2.11.2",
    "cypress": "^13.6.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "lighthouse": "^11.4.0",
    "pixelmatch": "^5.3.0",
    "puppeteer": "^21.6.1",
    "start-server-and-test": "^2.0.3",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  }
}
